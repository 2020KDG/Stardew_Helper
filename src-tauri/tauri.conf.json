{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stardew Helper",
  "version": "1.2.0",
  "identifier": "stardew.helper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Stardew Helper",
        "width": 1100,
        "height": 750,
        "url": "index.html",
        "transparent": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": false,
        "visible": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Stardew Overlay",
        "width": 800,
        "height": 600,
        "url": "overlay.html",
        "transparent": true,
        "fullscreen": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/**/*"]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/2020KDG/Stardew_Helper/releases/latest/download/updater.json"
      ],
      "pubkey": "RWQLG5F/Sd1afJ4ksmaq1+Um8yp5u4ICOg4CmtKAgCqb8sAg7fb0Qty1"
    }
  }
}
